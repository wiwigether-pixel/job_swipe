-- ============================================================
-- JobSwipe MVP 資料庫 Schema
-- 設計原則：
-- 1. 每個表都有 created_at/updated_at 自動時間戳記
-- 2. 使用 UUID 而非自增 ID（分散式安全、不洩漏數量資訊）
-- 3. RLS（Row Level Security）確保使用者只能看到自己的資料
-- ============================================================

-- 啟用 UUID 擴充套件（Supabase 預設已啟用，但明確宣告更安全）
create extension if not exists "uuid-ossp";

-- ─────────────────────────────────────────
-- 1. users 表：擴充 Supabase Auth 的使用者資訊
--    Supabase 的 auth.users 存帳號密碼，
--    這裡的 public.users 存 App 業務資料
-- ─────────────────────────────────────────
create table public.users (
  -- 與 auth.users 的 id 對應，用於 JOIN
  id uuid references auth.users(id) on delete cascade primary key,

  -- 使用者類型：求職者 或 雇主
  role text not null check (role in ('job_seeker', 'employer')),

  -- 基本資料
  display_name text not null,
  avatar_url text,
  bio text,                        -- 自我介紹（求職者）或 公司簡介（雇主）
  location text,                   -- 工作地點偏好

  -- 求職者專屬欄位（雇主為 null）
  skills text[],                   -- 技能清單，例如 {'Flutter', 'Dart', 'Firebase'}
  experience_years integer,        -- 年資
  expected_salary integer,         -- 期望薪資（月薪，單位：元）

  -- 雇主專屬欄位（求職者為 null）
  company_name text,
  company_size text check (
    company_size in ('1-10', '11-50', '51-200', '200+') or company_size is null
  ),

  -- 自動時間戳記
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now()
);

-- ─────────────────────────────────────────
-- 2. jobs 表：職缺資訊
-- ─────────────────────────────────────────
create table public.jobs (
  id uuid default uuid_generate_v4() primary key,

  -- 關聯到發布職缺的雇主
  employer_id uuid not null references public.users(id) on delete cascade,

  title text not null,
  description text not null,
  required_skills text[],
  salary_min integer,
  salary_max integer,
  location text,
  job_type text check (job_type in ('full_time', 'part_time', 'contract', 'remote')),

  -- 職缺狀態（open: 徵才中, closed: 已截止）
  status text not null default 'open' check (status in ('open', 'closed')),

  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now()
);

-- ─────────────────────────────────────────
-- 3. swipes 表：記錄每次滑卡動作
--    用於：避免重複顯示已滑過的卡片、計算配對
-- ─────────────────────────────────────────
create table public.swipes (
  id uuid default uuid_generate_v4() primary key,

  -- 做出滑卡動作的使用者
  swiper_id uuid not null references public.users(id) on delete cascade,

  -- 被滑的目標（可能是 job 或 user，MVP 先用 job）
  target_id uuid not null,
  target_type text not null check (target_type in ('job', 'user')),

  -- 滑卡方向
  direction text not null check (direction in ('left', 'right')),

  created_at timestamptz not null default now(),

  -- 防止對同一目標重複滑卡
  unique(swiper_id, target_id)
);

-- ─────────────────────────────────────────
-- 4. matches 表：雙向配對成功的記錄
-- ─────────────────────────────────────────
create table public.matches (
  id uuid default uuid_generate_v4() primary key,

  -- 求職者
  job_seeker_id uuid not null references public.users(id) on delete cascade,

  -- 職缺
  job_id uuid not null references public.jobs(id) on delete cascade,

  -- 雇主（冗餘存放，方便查詢）
  employer_id uuid not null references public.users(id) on delete cascade,

  -- 配對狀態
  status text not null default 'pending'
    check (status in ('pending', 'accepted', 'rejected')),

  created_at timestamptz not null default now(),

  -- 同一求職者和職缺只能有一個配對記錄
  unique(job_seeker_id, job_id)
);

-- ─────────────────────────────────────────
-- 自動更新 updated_at 的 Trigger 函數
-- ─────────────────────────────────────────
create or replace function update_updated_at_column()
returns trigger as $$
begin
  new.updated_at = now();
  return new;
end;
$$ language plpgsql;

-- 為每個需要的表掛上 Trigger
create trigger update_users_updated_at
  before update on public.users
  for each row execute function update_updated_at_column();

create trigger update_jobs_updated_at
  before update on public.jobs
  for each row execute function update_updated_at_column();

-- ─────────────────────────────────────────
-- RLS（Row Level Security）政策設定
-- 【安全實踐】沒有 RLS，任何人都能讀寫所有資料！
-- ─────────────────────────────────────────

-- 啟用 RLS
alter table public.users enable row level security;
alter table public.jobs enable row level security;
alter table public.swipes enable row level security;
alter table public.matches enable row level security;

-- users 表：只能讀取所有人的公開資料，但只能修改自己的資料
create policy "所有登入用戶可以讀取 users" on public.users
  for select using (auth.role() = 'authenticated');

create policy "用戶只能修改自己的資料" on public.users
  for update using (auth.uid() = id);

create policy "用戶只能插入自己的資料" on public.users
  for insert with check (auth.uid() = id);

-- jobs 表：所有登入用戶可以讀取，只有雇主可以建立/修改自己的職缺
create policy "所有登入用戶可以讀取職缺" on public.jobs
  for select using (auth.role() = 'authenticated');

create policy "雇主可以建立職缺" on public.jobs
  for insert with check (auth.uid() = employer_id);

create policy "雇主只能修改自己的職缺" on public.jobs
  for update using (auth.uid() = employer_id);

-- swipes 表：只能讀取/寫入自己的滑卡記錄
create policy "用戶只能存取自己的滑卡記錄" on public.swipes
  for all using (auth.uid() = swiper_id);

-- matches 表：配對雙方都可以讀取
create policy "配對雙方可以讀取配對記錄" on public.matches
  for select using (
    auth.uid() = job_seeker_id or auth.uid() = employer_id
  );